# Tradução do README (Lingva). Lista separada por vírgula para tentar vários hosts se um bloquear o IP do servidor.
# LINGVA_BASE_URLS=https://lingva.ml,https://outro-mirror.example
# ou um só:
# LINGVA_BASE_URL=https://lingva.ml

# Connect to Supabase via connection pooling
DATABASE_URL=
# Direct connection to the database. Used for migrations
DIRECT_URL=

# Ollama Cloud API: https://docs.ollama.com/cloud — chave em https://ollama.com/settings/keys (nunca commite .env)
OLLAMA_API_KEY=
# API base: https://ollama.com (rotas /api/chat, /api/tags). Local: http://localhost:11434 ou http://ollama:11434 no Docker
OLLAMA_HOST=https://ollama.com
# Cloud (API direta): nome como na biblioteca cloud, ex. gpt-oss:120b — ver https://ollama.com/search?c=cloud
# Local: igual a `ollama list` (ex. llama3.2). Se vazio, cloud usa gpt-oss:120b e local usa llama3.2
OLLAMA_MODEL=