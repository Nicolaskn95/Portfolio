# Obrigatório em produção: URL pública do Nest (ex.: https://api.seudominio.com).
# Alternativa (Vercel + API em outro host): defina BACKEND_URL abaixo e use NEXT_PUBLIC_API_URL=/portfolio-api
NEXT_PUBLIC_API_URL=
# Usado pelas Server Actions quando NEXT_PUBLIC_API_URL é relativo (/portfolio-api). Em Vercel costuma ser preenchido automaticamente.
NEXT_PUBLIC_SITE_URL=
# URL do Nest para Server Actions (Docker: http://backend:4000). Se vazio, usa NEXT_PUBLIC_API_URL.
API_URL=
# Só para rewrite /portfolio-api/* → backend (evita misturar origens e ajuda o README traduzir no browser).
BACKEND_URL=